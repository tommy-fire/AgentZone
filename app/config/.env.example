# Copy to /opt/agentzone/config/.env and fill in real values.
# install.sh does this for you automatically — this file is a reference.

# Telegram bot token from @BotFather. This example has the right general
# shape (<numeric-id>:<token>) but is not a working token (it can't be —
# no_pii_allow).
BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA  # no_pii_allow

# Your Telegram numeric user ID (single admin, by design).
ADMIN_ID=123456789

# Public IPv4 of this server. install.sh auto-detects this; it is only ever
# shown to the admin in a private Telegram message, never logged publicly.
SERVER_IP=203.0.113.10

# TCP port range the helper allocates one port per grant from.
AGENTZONE_PORT_RANGE_START=20000
AGENTZONE_PORT_RANGE_END=20100

# Internal paths — normally left at their defaults.
AGENTZONE_HELPER_PATH=/usr/local/sbin/agentzone-helper
AGENTZONE_STATE_DIR=/var/lib/agentzone
